#!/usr/bin/bash

processes=$(ps ax)

function execute_once {
    if ! echo $processes | grep $1 > /dev/null; then
        echo "Running $1"
        $@
    else
        echo "Skipping $1"
    fi
}

autorandr --change
nitrogen --restore
sleep 1
xset r rate 180 70

# Applets
execute_once indicator-sound-switcher
execute_once nm-applet
execute_once gxkb # keyboard layout indicator

sleep 10
compton-blur
